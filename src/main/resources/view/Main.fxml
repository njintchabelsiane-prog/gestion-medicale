<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.medical.controller.MainController"
            prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color: #F4F6F9;">

    <!-- ========== SIDEBAR GAUCHE ========== -->
    <left>
        <VBox prefWidth="260" style="-fx-background-color: linear-gradient(to bottom, #1E3A8A, #2E6DA4);">
            <padding>
                <Insets top="30" right="20" bottom="30" left="20"/>
            </padding>

            <!-- Logo / Titre -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="⚕" style="-fx-font-size: 48px; -fx-text-fill: white;"/>
                <Label text="Gestion Médicale" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Espace Professionnel" style="-fx-font-size: 11px; -fx-text-fill: #BFDBFE;"/>
            </VBox>

            <Separator>
                <VBox.margin>
                    <Insets top="25" bottom="25"/>
                </VBox.margin>
            </Separator>

            <!-- Menu -->
            <Label text="MENU" style="-fx-font-size: 10px; -fx-text-fill: #93C5FD; -fx-font-weight: bold;">
                <VBox.margin>
                    <Insets bottom="10" left="10"/>
                </VBox.margin>
            </Label>

            <Button fx:id="btnDashboard" text="🏠   Tableau de bord" onAction="#showDashboard"
                    maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Button>

            <Button fx:id="btnPatients" text="👥   Patients" onAction="#showPatients"
                    maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Button>

            <Button fx:id="btnMedecins" text="🩺   Médecins" onAction="#showMedecins"
                    maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-cursor: hand;">
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Button>

            <Button fx:id="btnConsultations" text="📋   Consultations" onAction="#showConsultations"
                    maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- User info + Déconnexion -->
            <VBox spacing="10" style="-fx-background-color: rgba(0,0,0,0.2); -fx-background-radius: 10; -fx-padding: 15;">
                <Label fx:id="lblUtilisateur" text="Utilisateur" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblRole" text="Rôle" style="-fx-text-fill: #BFDBFE; -fx-font-size: 11px;"/>
                <Button text="🚪  Déconnexion" onAction="#handleLogout"
                        maxWidth="Infinity"
                        style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ========== ZONE CENTRALE ========== -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="contentArea" spacing="25">
                <padding>
                    <Insets top="35" right="35" bottom="35" left="35"/>
                </padding>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT">
                    <VBox>
                        <Label fx:id="lblTitre" text="Tableau de bord" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                        <Label fx:id="lblSousTitre" text="Vue d'ensemble de votre activité" style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblDate" text="" style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                </HBox>

                <!-- Cartes statistiques -->
                <HBox spacing="20">
                    <!-- Carte Patients -->
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="👥" style="-fx-font-size: 28px;"/>
                            <Label text="Patients" style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblNbPatients" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                        <Label text="Total enregistrés" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>

                    <!-- Carte Médecins -->
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🩺" style="-fx-font-size: 28px;"/>
                            <Label text="Médecins" style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblNbMedecins" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                        <Label text="Praticiens actifs" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>

                    <!-- Carte Consultations -->
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📋" style="-fx-font-size: 28px;"/>
                            <Label text="Consultations" style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblNbConsultations" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                        <Label text="Total enregistrées" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>

                    <!-- Carte Aujourd'hui -->
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: linear-gradient(to bottom right, #2E6DA4, #1E3A8A); -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📅" style="-fx-font-size: 28px;"/>
                            <Label text="Aujourd'hui" style="-fx-font-size: 13px; -fx-text-fill: #BFDBFE; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblNbAujourdhui" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Consultations du jour" style="-fx-font-size: 11px; -fx-text-fill: #BFDBFE;"/>
                    </VBox>
                </HBox>

                <!-- Section info -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <Label text="Bienvenue dans votre espace" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                    <Label text="Sélectionnez un module dans le menu de gauche pour gérer vos patients, médecins et consultations. Toutes vos données sont sécurisées et accessibles en temps réel."
                           wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>