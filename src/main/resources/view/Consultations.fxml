<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.medical.controller.ConsultationsController"
      spacing="20" style="-fx-background-color: #F4F6F9;">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="Gestion des Consultations" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
            <Label text="Historique de toutes les consultations" style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvelle consultation" onAction="#handleAjouter"
                style="-fx-background-color: #1E3A8A; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
        <TableView fx:id="tableConsultations" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                <TableColumn fx:id="colPatient" text="Patient" prefWidth="180"/>
                <TableColumn fx:id="colMedecin" text="Medecin" prefWidth="180"/>
                <TableColumn fx:id="colMotif" text="Motif" prefWidth="200"/>
                <TableColumn fx:id="colDiagnostic" text="Diagnostic" prefWidth="200"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <VBox.margin>
                <Insets top="15"/>
            </VBox.margin>
            <Button text="Modifier" onAction="#handleModifier"
                    style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 18 8 18; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Button text="Supprimer" onAction="#handleSupprimer"
                    style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 18 8 18; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</VBox>