<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="400.0" spacing="15.0"
      style="-fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.medical.controller.LoginController">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E6DA4;"
           text="Gestion Médicale" />

    <Label style="-fx-font-size: 14px; -fx-text-fill: #555;"
           text="Connectez-vous à votre compte" />

    <VBox spacing="5.0">
        <Label text="Email" style="-fx-font-weight: bold;" />
        <TextField fx:id="emailField" promptText="admin@medical.fr"
                   style="-fx-font-size: 14px; -fx-padding: 8;" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Mot de passe" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="passwordField" promptText="••••••••"
                       style="-fx-font-size: 14px; -fx-padding: 8;" />
    </VBox>

    <Button fx:id="loginButton" onAction="#handleLogin" text="Se connecter"
            maxWidth="Infinity"
            style="-fx-background-color: #2E6DA4; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10;" />

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" />

</VBox>